# ==========================================
# MIS SOCIOS 24/7 - MANIFIESTO DE ENTORNO
# ==========================================

# 1. Configuración del Bot (Telegram)
TELEGRAM_TOKEN=tu_telegram_bot_token_aqui

# 2. Configuración de Inteligencia Artificial (Gemini)
GOOGLE_API_KEY=tu_google_api_key_aqui

# 3. Adaptador RAG (El Motor de Memoria Desacoplada)
# Opciones soportadas: pgvector, notebooklm
RAG_ENGINE=pgvector

# 3.1 Motor NotebookLM Enterprise (Para uso a futuro si RAG_ENGINE=notebooklm)
NOTEBOOK_LM_ENDPOINT=https://api.notebooklm.google.com/v1/query
NOTEBOOK_LM_API_KEY=tu_notebook_lm_key_aqui

# 4. Base de Datos (PostgreSQL con PGVector integrado)
# Formato: postgresql://[usuario]:[contraseña]@[host]:[puerto]/[basededatos]
# NOTA: En Docker Compose, el host suele ser el nombre del servicio (ej. 'db')
DATABASE_URL=postgresql://ms247_admin:secreto_super_seguro@db:5432/ms247_db

# (Opcional) Variables nativas de base de datos para levantar el contenedor PostgreSQL
POSTGRES_USER=ms247_admin
POSTGRES_PASSWORD=secreto_super_seguro
POSTGRES_DB=ms247_db
